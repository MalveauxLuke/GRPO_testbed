# Human-editable front-door config for the DeepScaleR-style GDPO production run.

EXPERIMENT_TITLE="Math-length GDPO production"
EXPERIMENT_WORKFLOW="math"
EXPERIMENT_DESCRIPTION="Production DeepScaleR-style GDPO run using the current correctness plus length reward contract."
EXPERIMENT_SUBMIT_TARGET="slurm/gdpo_math_length_production.sbatch"
EXPERIMENT_DRY_RUN_TARGET="scripts/sol/run_gdpo_math_length_production.sh"
EXPERIMENT_POST_RUN_AUDIT='python scripts/sol/audit_math_length_rewards.py recompute-summary --input-path "$MATH_LENGTH_ROLLOUT_DATA_DIR" --input-type rollout'
EXPERIMENT_ROLLOUT_ENV_VAR="MATH_LENGTH_ROLLOUT_DATA_DIR"
EXPERIMENT_ROLLOUT_PREFIX="math_length_gdpo_production"
EXPERIMENT_PRINT_ENV_VARS="
MATH_LENGTH_MODEL_PATH
MATH_LENGTH_EXPERIMENT_NAME
MATH_LENGTH_PROJECT_NAME
MATH_LENGTH_TOTAL_TRAINING_STEPS
MATH_LENGTH_LIMIT_TOKENS
MATH_LENGTH_N_GPUS_PER_NODE
MATH_LENGTH_ROLLOUT_DATA_DIR
"

export MATH_LENGTH_MODEL_PATH="${MATH_LENGTH_MODEL_PATH:-deepseek-ai/DeepSeek-R1-Distill-Qwen-1.5B}"
export MATH_LENGTH_EXPERIMENT_NAME="${MATH_LENGTH_EXPERIMENT_NAME:-DeepSeek-R1-Distill-Qwen-1.5B_gdpo_math_length_sol}"
export MATH_LENGTH_PROJECT_NAME="${MATH_LENGTH_PROJECT_NAME:-${SOL_PROJECT_NAME}_gdpo_math_length}"
export MATH_LENGTH_TOTAL_TRAINING_STEPS="${MATH_LENGTH_TOTAL_TRAINING_STEPS:-500}"
export MATH_LENGTH_LIMIT_TOKENS="${MATH_LENGTH_LIMIT_TOKENS:-4000}"
export MATH_LENGTH_N_GPUS_PER_NODE="${MATH_LENGTH_N_GPUS_PER_NODE:-8}"
