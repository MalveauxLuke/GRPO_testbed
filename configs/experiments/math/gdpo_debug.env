# Human-editable front-door config for the DeepScaleR-style GDPO math debug run.

EXPERIMENT_TITLE="Math-length GDPO debug"
EXPERIMENT_WORKFLOW="math"
EXPERIMENT_DESCRIPTION="Short debug-safe DeepScaleR-style GDPO run using correctness plus length reward."
EXPERIMENT_SUBMIT_TARGET="slurm/gdpo_math_length_debug.sbatch"
EXPERIMENT_DRY_RUN_TARGET="scripts/sol/run_gdpo_math_length_debug.sh"
EXPERIMENT_POST_RUN_AUDIT='python scripts/sol/audit_math_length_rewards.py recompute-summary --input-path "$MATH_LENGTH_ROLLOUT_DATA_DIR" --input-type rollout'
EXPERIMENT_ROLLOUT_ENV_VAR="MATH_LENGTH_ROLLOUT_DATA_DIR"
EXPERIMENT_ROLLOUT_PREFIX="math_length_gdpo_debug"
EXPERIMENT_PRINT_ENV_VARS="
MATH_LENGTH_MODEL_PATH
MATH_LENGTH_EXPERIMENT_NAME
MATH_LENGTH_PROJECT_NAME
MATH_LENGTH_TOTAL_TRAINING_STEPS
MATH_LENGTH_LIMIT_TOKENS
MATH_LENGTH_ROLLOUT_DATA_DIR
"

export MATH_LENGTH_MODEL_PATH="${MATH_LENGTH_MODEL_PATH:-Qwen/Qwen2.5-0.5B-Instruct}"
export MATH_LENGTH_EXPERIMENT_NAME="${MATH_LENGTH_EXPERIMENT_NAME:-Qwen2.5-0.5B-Instruct_gdpo_math_length_sol_debug}"
export MATH_LENGTH_PROJECT_NAME="${MATH_LENGTH_PROJECT_NAME:-${SOL_PROJECT_NAME}_gdpo_math_length}"
export MATH_LENGTH_TOTAL_TRAINING_STEPS="${MATH_LENGTH_TOTAL_TRAINING_STEPS:-5}"
export MATH_LENGTH_LIMIT_TOKENS="${MATH_LENGTH_LIMIT_TOKENS:-1024}"
